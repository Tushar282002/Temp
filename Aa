
// Key pattern: "addTeamMembers_{opportunityId}"
private _getCheckboxStorageKey(): string {
  const opportunityId = this._opportunityReadService.opportunity.value?.opportunityId ?? '';
  return `addTeamMembers_${opportunityId}`;
}

private _saveCheckboxState(checked: boolean): void {
  const key = this._getCheckboxStorageKey();
  if (checked) {
    localStorage.setItem(key, 'true');
  } else {
    localStorage.removeItem(key);
  }
}

private _loadCheckboxState(): boolean {
  const key = this._getCheckboxStorageKey();
  return localStorage.getItem(key) === 'true';
}




private _inferCheckboxState(loadedList: IAccessList[], teamMembers: TeamMember[]): void {
  const validTeamMemberIds = new Set(
    teamMembers
      .filter(tm =>
        tm.ppi && tm.ppi.trim() !== '' &&
        tm.s?.toLowerCase() === 'active'
      )
      .map(tm => tm.eid)
  );

  if (validTeamMemberIds.size === 0) {
    this.addTeamMembers = false;
    return;
  }

  // Read persisted checkbox state from localStorage
  const wasPreviouslyChecked = this._loadCheckboxState();
  this.addTeamMembers = wasPreviouslyChecked;

  if (wasPreviouslyChecked) {
    // Repopulate tracking set — only Manually Added team members
    // These were added via checkbox (System Added rows are never touched)
    loadedList.forEach(al => {
      if (
        al.id &&
        validTeamMemberIds.has(al.id) &&
        al.visibilityRules === 'Manually Added'
      ) {
        this._teamCheckboxAddedIds.add(al.id);
      }
    });
  }
}


protected saveUpdatedAccessList(): void {
