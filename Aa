  private _inferCheckboxState(loadedList: IAccessList[], teamMembers: TeamMember[]): void {
    // BUG FIX: was == '' which KEPT members WITHOUT positionId
    // Correct: !== '' keeps only members WITH positionId
    const validTeamMemberIds = new Set(
      teamMembers
        .filter(tm => tm.ppi && tm.ppi.trim() !== '')
        .map(tm => tm.eid)
    );

    if (validTeamMemberIds.size === 0) {
      this.addTeamMembers = false;
      return;
    }

    // Checkbox was previously checked if at least one team member
    // exists in the saved list as manually added
    const atLeastOnePresent = loadedList.some(
      al => al.id && validTeamMemberIds.has(al.id) && al.isManuallyAdded
    );

    this.addTeamMembers = atLeastOnePresent;

    if (atLeastOnePresent) {
      // Rebuild tracking set so uncheck removes the right rows
      loadedList.forEach(al => {
        if (al.id && validTeamMemberIds.has(al.id)) {
          this._teamCheckboxAddedIds.add(al.id);
        }
      });
    }
  }

