              this._inferCheckboxState(result, teamMembers);
            }
          );
        });
      });
  }

  /**
   * Resolves the current logged-in user's team name.
   * Searches by the current user's own first name — guaranteed to return
   * their own record which has teamName populated by the API.
   * Falls back to any teamName already in the loaded grid rows.
   */
  private _resolveCurrentUserTeamName(onResolved: () => void): void {
    const firstName = this._userService.context?.firstName ?? '';

    if (!firstName) {
      onResolved();
      return;
    }

    this._employeeService
      .searchEmployeesForVisibility(firstName)
      .pipe(
        takeUntil(this.destroy$),
        map(employees => {
          // Find the current user's own record by matching employeeId or globalUserId
          const globalUserId = this._userService.context?.globalUserId?.toLowerCase() ?? '';
          const employeeId = this._userService.context?.employeeId ?? '';

          // Try to match by employeeId first, then by uid match via globalUserId
          const ownRecord = employees.find(e =>
            e.id === employeeId ||
            (e as any).uid?.toLowerCase() === globalUserId
          );

          // If own record not found, take first result with a teamName
          // (likely same team since searching by first name)
          return ownRecord?.teamName
            ?? employees.find(e => e.teamName && e.teamName.trim() !== '')?.teamName
            ?? '';
        })
      )
      .subscribe({
        next: (teamName) => {
          this._currentUserTeamName = teamName;
          onResolved();
        },
        error: () => {
          // If search fails, continue without team name — Siebel fills it on reopen
          onResolved();
        }
      });
  }

