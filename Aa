    if (_listsOfClients[ClientListType.MyBusinessLineTeamClients] != null)
    {
        var client = _listsOfClients[ClientListType.MyBusinessLineTeamClients]
            .FirstOrDefault(x => x.Id == clientId);

        if (client != null && client.StrategicClient != strategicValue)
        {
            _listsOfClients[ClientListType.MyBusinessLineTeamClients].Remove(client);
