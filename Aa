  protected opportunityType = '';
  protected privacyLevel = '';
  protected visibilityMessage = '';
  protected addTeamMembers = false;
  manuallyAddedEmployee = model<Employee[]>([]);

  private _teamCheckboxAddedIds = new Set<string>();
  private _cachedTeamMembers: TeamMember[] = [];

  // Senior's suggestion: use current user's team name from their own employee record
  // This is fetched once via searchEmployeesForVisibility using the logged-in user's
  // own name — guaranteed to return at least one result with teamName populated
  private _currentUserTeamName = '';

  ngOnInit(): void {
    this._opportunityReadService.opportunityObservable
      .pipe(takeUntil(this.destroy$))
      .subscribe((opportunity: IOpportunityModel) => {
        this.opportunityType = opportunity.opportunityType ?? '';
        this.privacyLevel = opportunity.privacyLevel ?? '';
        this.visibilityMessage = this.buildVisibilityMessage();
      });
  }

  protected onGridReady(): void {
    const globalUserId = this._userService.context?.globalUserId?.toUpperCase() ?? '';

    // Step 1: Fetch team members (for checkbox functionality)
    this._employeeService
      .fetchTeamMembers(globalUserId)
      .pipe(takeUntil(this.destroy$))
      .subscribe((teamMembers: TeamMember[]) => {
        this._cachedTeamMembers = teamMembers;

        // Step 2: Resolve current user's team name by searching their own name
        // Senior's suggestion: use logged-in user's own team name for all 
        // checkbox-added members since GetTeamMembers doesn't return team name
        this._resolveCurrentUserTeamName(() => {

          // Step 3: Load the access list
          this.processApiCall(
            this._opportunityReadService.GetOpportunityVisibilityList(),
            'Error fetching access list',
            (result: IAccessList[]) => {
              this.accessListRowData.set(result);

              // Step 4: Infer checkbox state from loaded data
              this._inferCheckboxState(result, teamMembers);
            }
          );
        });
      });
  }

  /**
   * Resolves the current logged-in user's team name.
   * Searches by the current user's own first name — guaranteed to return
   * their own record which has teamName populated by the API.
   * Falls back to any teamName already in the loaded grid rows.
   */
  private _resolveCurrentUserTeamName(onResolved: () => void): void {
    const firstName = this._userService.context?.firstName ?? '';

    if (!firstName) {
      onResolved();
      return;
    }

    this._employeeService
      .searchEmployeesForVisibility(firstName)
      .pipe(
        takeUntil(this.destroy$),
        map(employees => {
          // Find the current user's own record by matching employeeId or globalUserId
          const globalUserId = this._userService.context?.globalUserId?.toLowerCase() ?? '';
          const employeeId = this._userService.context?.employeeId ?? '';

          // Try to match by employeeId first, then by uid match via globalUserId
          const ownRecord = employees.find(e =>
            e.id === employeeId ||
            (e as any).uid?.toLowerCase() === globalUserId
          );

          // If own record not found, take first result with a teamName
          // (likely same team since searching by first name)
          return ownRecord?.teamName
            ?? employees.find(e => e.teamName && e.teamName.trim() !== '')?.teamName
            ?? '';
        })
      )
      .subscribe({
        next: (teamName) => {
          this._currentUserTeamName = teamName;
          onResolved();
        },
        error: () => {
          // If search fails, continue without team name — Siebel fills it on reopen
          onResolved();
        }
      });
  }

  /**
   * Infer checkbox checked state on reopen.
   * Checked if at least one team member is present in loaded list as manually added.
   * This handles: checked + removed some + saved → still checked on reopen.
   */
  private _inferCheckboxState(loadedList: IAccessList[], teamMembers: TeamMember[]): void {
    // BUG FIX: was == '' which KEPT members WITHOUT positionId
    // Correct: !== '' keeps only members WITH positionId
    const validTeamMemberIds = new Set(
      teamMembers
